\u0438\u0442\u044c\u0441\u044f \u044d\u0442\u0438\u043c \u0447\u0443\u0432\u0441\u0442\u0432\u043e\u043c \u0434\u043e\u043c\u0430. \u0412 \u0442\u0430\u043a\u0438\u0435 \u043c\u043e\u043c\u0435\u043d\u0442\u044b \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e \u0445\u043e\u0447\u0435\u0442\u0441\u044f \u043f\u0440\u0438\u0433\u043e\u0442\u043e\u0432\u0438\u0442\u044c \u0447\u0442\u043e-\u0442\u043e \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e\u0435 \u2014 \u043d\u0435 \u043f\u0440\u0438\u0432\u044b\u0447\u043d\u044b\u0435 \u0441\u044b\u0440\u043d\u0438\u043a\u0438 \u0438\u043b\u0438 \u0431\u043b\u0438\u043d\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0434\u0435\u043b\u0430\u0435\u0448\u044c \u043d\u0430 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0435, \u0430 \u0431\u043b\u044e\u0434\u043e, \u043a \u043a\u043e\u0442\u043e\u0440\u043e\u043c\u0443 \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0448\u044c\u0441\u044f \u043d\u0435 \u0442\u0430\u043a \u0447\u0430\u0441\u0442\u043e, \u043d\u043e \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u043e\u0441\u043e\u0431\u0435\u043d\u043d\u043e \u043b\u044e\u0431\u0438\u0448\u044c. \u0422\u043e\u0433\u0434\u0430 \u0440\u0443\u043a\u0430 \u0441\u0430\u043c\u0430 \u0442\u044f\u043d\u0435\u0442\u0441\u044f \u043a \u043a\u043d\u0438\u0433\u0435\u2026 \u043d\u043e \u0435\u0451, \u043a\u043e\u043d\u0435\u0447\u043d\u043e, \u0440\u044f\u0434\u043e\u043c \u043d\u0435\u0442.<\/p><p>\u0422\u043e\u0433\u0434\u0430 \u0438 \u043f\u0440\u0438\u0448\u043b\u0430 \u043c\u044b\u0441\u043b\u044c: \u043d\u0443\u0436\u043d\u0430 \u044d\u043b\u0435\u043a\u0442\u0440\u043e\u043d\u043d\u0430\u044f \u043a\u043d\u0438\u0433\u0430. \u041d\u043e \u043a\u0430\u043a\u0430\u044f? \u0417\u0430\u043c\u0435\u0442\u043a\u0438 \u0432 \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0435 \u2014 \u043d\u0435 \u0441\u0430\u043c\u044b\u0439 \u043d\u0430\u0434\u0451\u0436\u043d\u044b\u0439 \u0432\u0430\u0440\u0438\u0430\u043d\u0442: \u0441\u043c\u0430\u0